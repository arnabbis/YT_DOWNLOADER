PORT=3000
HOST=0.0.0.0
NODE_ENV=development
DOWNLOAD_DIR=server/downloads
TEMP_DIR=server/temp
LOG_DIR=server/logs
MAX_DOWNLOADS=1
DOWNLOAD_FRAGMENTS=32
DOWNLOAD_HTTP_CHUNK_SIZE=20M
DOWNLOAD_BUFFER_SIZE=32K
DOWNLOAD_THROTTLED_RATE=100K
FAST_VIDEO_MODE=true
FAST_AUDIO_MODE=true
FAST_TRIM_MODE=true
SECTION_DOWNLOAD_MODE=false
FORCE_KEYFRAMES_AT_CUTS=true
MAX_PREVIEW_SECONDS=180
FFMPEG_VIDEO_PRESET=ultrafast
YTDLP_EXTERNAL_DOWNLOADER=
YTDLP_EXTERNAL_DOWNLOADER_ARGS=
CLEANUP_INTERVAL_MINUTES=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
